---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { subjects } from '../../data/subjects';
import { withBase } from '../../utils';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({ params: { id: note.id }, props: { note } }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const subjectTitle = subjects.find((s) => s.id === note.data.subject)?.title;
---

<Base title={note.data.title}>
  <article class="prose">
    <p class="eyebrow">
      <a href={withBase(`/${note.data.subject}/`)}>{subjectTitle}</a> · {note.data.topic} · Notes
    </p>
    <h1>{note.data.title}</h1>
    <Content />
  </article>
</Base>

<style>
  article {
    padding-top: 2.2rem;
  }
  .eyebrow a {
    color: inherit;
  }
</style>
